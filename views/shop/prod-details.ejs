<%- include("../includes/header"); -%>

<link rel="stylesheet" href="/CSS/style.css" type="text/css">

</head>
<body>

<main>

<%- include("../includes/navigation"); %> 

<div class="grid container">
    <div class="grid-box row justify-content-md-center">

        <div class="single-grid col col-lg-3 col-md-6 col-sm-12">
            <div class="image">
                <img src="/<%= products.imgurl %> " class="img-thumbnail" alt="Image">
            </div>
            <div class="content">
                <h4 class="product-title"><%= products.title %> </h4>
                <h4 class="product-price">$<%= products.price %> </h4>
                <p class="product-description"><%= products.discription %> </p>
            </div>
            <div class="buttons">
                <button class="add-cart btn btn-dark"><i class="fas fa-cart-arrow-down"></i><span class="icon-space">Add to cart</span></button>
            </div>
        </div>
        
    </div>
</div>
</main>

<%- include("../includes/footer"); -%>